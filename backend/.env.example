# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=production   # set to "development" for dev mode with CORS

# ── Bybit Trading (optional) ──────────────────────────────
# Create API keys at: https://www.bybit.com/app/user/api-management
# Permissions needed: Unified Trade, Read positions
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── Telegram (optional) ───────────────────────────────────
# 1. Create a bot with @BotFather on Telegram → copy the token
# 2. Get your Chat ID via @userinfobot or by messaging your bot
#    and calling https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
