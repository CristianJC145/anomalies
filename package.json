{
  "name": "volume-spike-bot",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "build":       "npm run --prefix frontend build",
    "start":       "cross-env NODE_ENV=production node backend/server.js",
    "dev":         "start-backend-and-frontend",
    "pm2:start":   "pm2 start ecosystem.config.js",
    "pm2:stop":    "pm2 stop volume-spike-bot",
    "pm2:restart": "pm2 restart volume-spike-bot",
    "pm2:logs":    "pm2 logs volume-spike-bot",
    "setup":       "npm run install:all && npm run build"
  },
  "dependencies": {
    "cross-env": "^7.0.3"
  }
}
